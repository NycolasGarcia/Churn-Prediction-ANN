# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# Notebook builders: auxiliary Python scripts that generate the .ipynb
# via nbformat. The .ipynb is the tracked deliverable; the builder is
# local-only tooling and must not be committed.
notebooks/*.py

# --- Data ---
# We DO version data/raw/raw_data.xlsx (educational dataset, ~1.3MB).
# Ignore everything else under data/, then unignore the file we want to keep.
data/processed/
data/raw/*
!data/raw/raw_data.xlsx

# --- Trained models / artifacts ---
models/*
!models/.gitkeep

# --- MLflow ---
mlruns/
mlartifacts/
*.db

# --- Pytest / coverage / ruff caches ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/

# --- Environment files ---
.env
*.env
.env.*

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
